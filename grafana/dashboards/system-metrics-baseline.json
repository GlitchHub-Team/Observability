{
  "uid": "system-metrics-baseline",
  "title": "System Metrics - Baseline",
  "tags": ["observability", "baseline", "nats", "mvp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Current Scope",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### Baseline Observability\nCurrent data comes from **NATS Exporter**. This dashboard shows transport and broker health metrics already available in the repository baseline.\n\nFuture domain metrics such as **gateway online/offline**, **payload size**, **data staleness** and **Data Consumer write metrics** will appear here after the other services expose `/metrics`."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prometheus Target",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"nats\"})",
          "legendFormat": "nats target"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum({job=\"nats\",__name__=~\"(gnatsd|nats)_varz_connections\"})",
          "legendFormat": "connections"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ingress Msg/s",
      "datasource": {
